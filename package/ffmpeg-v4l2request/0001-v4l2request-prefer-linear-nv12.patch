+        struct v4l2_fmtdesc fd = { .type = type };
+        while (ioctl(ctx->video_fd, VIDIOC_ENUM_FMT, &fd) >= 0) {
+            if (fd.pixelformat == want)
+                return v4l2_request_set_format(avctx, type, want, 0);
+            fd.index++;
+        }
+    }
