#!/bin/sh
# DEBUG: dump boot/network/wifi state to the FAT 'DVR' partition so it can be
# read offline (pull the SD into any computer) without serial/keyboard/network.
case "$1" in
	start)
		( sleep 5
		  DVR=$(blkid -L DVR 2>/dev/null)
		  [ -n "$DVR" ] || exit 0
		  mkdir -p /mnt/_diag
		  mount "$DVR" /mnt/_diag 2>/dev/null || exit 0
		  D=/mnt/_diag/diag
		  rm -rf "$D"; mkdir -p "$D"
		  uname -a            > "$D/uname.txt"     2>&1
		  dmesg               > "$D/dmesg.txt"     2>&1
		  lsmod               > "$D/lsmod.txt"     2>&1
		  cat /proc/modules   > "$D/modules.txt"   2>&1
		  ip -d link          > "$D/ip-link.txt"   2>&1
		  ip addr             > "$D/ip-addr.txt"   2>&1
		  ls -la /sys/class/net > "$D/netdevs.txt" 2>&1
		  iw dev              > "$D/iw-dev.txt"     2>&1
		  iw phy              > "$D/iw-phy.txt"     2>&1
		  ls -la /lib/firmware/uwe5622 > "$D/fw.txt" 2>&1
		  ls -d /sys/class/ieee80211/* > "$D/phys.txt" 2>&1
		  ps                  > "$D/ps.txt"         2>&1
		  logread             > "$D/logread.txt"    2>&1
		  cat /proc/mounts    > "$D/mounts.txt"     2>&1
		  sync
		  umount /mnt/_diag 2>/dev/null ) &
		;;
esac
