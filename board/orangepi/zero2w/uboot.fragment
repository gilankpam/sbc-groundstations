CONFIG_CMD_SQUASHFS=y
CONFIG_FS_SQUASHFS=y
CONFIG_ZSTD=y
CONFIG_BOOTDELAY=1
# Explicit boot from the squashfs rootfs (mmc 0:1) at fixed paths — bypasses the
# bootstd/extlinux scan + $fdtfile lookup; falls back to distro_bootcmd if any
# step fails. (No serial console available; AP coming up == booted.)
CONFIG_USE_BOOTCOMMAND=y
CONFIG_BOOTCOMMAND="load mmc 0:1 ${kernel_addr_r} /boot/Image && load mmc 0:1 ${fdt_addr_r} /boot/allwinner/sun50i-h618-orangepi-zero2w.dtb && setenv bootargs console=ttyS0,115200 console=tty1 consoleblank=0 root=/dev/mmcblk0p1 rootfstype=squashfs ro rootwait cma=256M init=/init && booti ${kernel_addr_r} - ${fdt_addr_r}; run distro_bootcmd"
